rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Payments collection - only authenticated users can read their own
    match /payments/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }
    
    // CVs collection - users can read their own CVs
    match /cvs/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }
    
    // Tokens collection - only authenticated users for verification
    match /tokens/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }
    
    // Access logs - read only for authenticated users
    match /access_logs/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can write
    }
    
    // Metadata collection
    match /_meta/{document=**} {
      allow read, write: if false;
    }
  }
}
