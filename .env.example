# Copy this file to .env and fill with your credentials

# Firebase
FIREBASE_PROJECT_ID=
# For local development, base64-encode your Firebase service account key and set:
# FIREBASE_CONFIG_JSON=<base64-encoded-service-account-key>
# Or point to a local service account JSON file:
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# Or use Google application default credentials:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# OpenAI
OPENAI_API_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=
PAYPAL_WEBHOOK_ID=

# M-Pesa (Safaricom)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Server
PORT=
NODE_ENV=

# CORS
ALLOWED_ORIGINS=

# API Admin Token (for admin endpoints)
API_ADMIN_TOKEN=

